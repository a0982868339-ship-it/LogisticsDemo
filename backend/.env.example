# ── LLM 配置 ───────────────────────────────────────────
# 填写 OpenAI API Key，或兼容接口的 Key（Azure/Ollama 等）
OPENAI_API_KEY=sk-xxxxxx
# 使用 Ollama 本地模型时，设置 base_url 并将 model 改为本地模型名称
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL_NAME=qwen2.5:7b

OPENAI_MODEL_NAME=gpt-4o-mini

# ── 知识库路径 ───────────────────────────────────────────
DOCS_DIR=../docs/巡检手册
CHROMA_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── 应用设置 ─────────────────────────────────────────────
APP_PORT=8000
LOG_LEVEL=INFO
MAX_REPLAN_COUNT=3

# ── 安全阈值 ─────────────────────────────────────────────
SALT_SPRAY_THRESHOLD=15.0     # mg/m³
VOC_THRESHOLD=1.0              # mg/m³
TEMP_MAX=50.0                  # °C
HUMIDITY_MAX=85.0              # % RH
